# Frontend env for local dev and Vercel
VITE_CONVEX_URL=https://your-convex-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-convex-project.convex.site

# Convex backend env. Set these with `npx convex env set NAME VALUE`.
# SITE_URL should be your website origin, for example http://127.0.0.1:5180 locally or https://your-site.vercel.app in production.
SITE_URL=http://127.0.0.1:5180
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
BETTER_AUTH_SECRET=replace-with-long-random-secret
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="RRDCH <onboarding@resend.dev>"
EMAIL_REPLY_TO=your-reply-to-email@example.com
